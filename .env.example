# Telegram Bot Configuration
# These variables are required for application form submissions and contact form
# notifications to be sent to your Telegram chat.
#
# HOW TO SET UP:
#
# 1. Create a Telegram bot:
#    - Open Telegram and search for @BotFather
#    - Send /newbot and follow the prompts
#    - Copy the bot token you receive (e.g. 123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ)
#
# 2. Get your Chat ID:
#    - Add your new bot to the Telegram group/channel where you want notifications
#    - Send a message in the group
#    - Visit https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
#    - Look for "chat":{"id": YOUR_CHAT_ID} in the response
#    - For groups, the ID is usually negative (e.g. -1001234567890)
#
# 3. Copy this file to .env and fill in your values:
#    cp .env.example .env
#
# 4. For production (Netlify):
#    - Go to Netlify dashboard > Site settings > Environment variables
#    - Add VITE_TELEGRAM_BOT_TOKEN and VITE_TELEGRAM_CHAT_ID with your values
#
VITE_TELEGRAM_BOT_TOKEN=your_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_chat_id_here

# EmailJS Configuration
# These variables are required to receive application submissions via email
# at admin@baeaerosystems.com.
#
# HOW TO SET UP:
#
# 1. Sign up at https://www.emailjs.com (free tier: 200 emails/month)
#
# 2. Add an Email Service:
#    - Go to "Email Services" and click "Add New Service"
#    - Choose your email provider (e.g. Gmail, Outlook, or Custom SMTP)
#    - Connect your email account
#    - Copy the Service ID (e.g. service_xxxxxxx)
#
# 3. Create an Email Template:
#    - Go to "Email Templates" and click "Create New Template"
#    - Set the "To Email" field to: {{to_email}}
#    - Set the "Subject" field to: {{subject}}
#    - In the template body, use these variables:
#        Applicant: {{applicant_name}}
#        Applicant Email: {{applicant_email}}
#        Details:
#        {{message}}
#    - Save the template and copy the Template ID (e.g. template_xxxxxxx)
#
# 4. Get your Public Key:
#    - Go to "Account" > "General" tab
#    - Copy your Public Key
#
# 5. For production (Netlify):
#    - Add these three variables in Netlify dashboard > Site settings > Environment variables
#
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
